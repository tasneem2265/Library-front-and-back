@* Views/Books/Index.cshtml *@
@model List<Book>
@{
    ViewData["Title"] = "الكتب";
    var categories = ViewBag.Categories as List<Category>;
}

<div class="row">
    @* Sidebar الفلترة *@
    <div class="col-md-3">
        <div class="card p-3 mb-4" style="border-color: var(--gold); border-width: 2px;">
            <h6 style="color: var(--wood-medium);">بحث</h6>
            <form asp-action="Index" method="get" class="mb-3">
                <input type="hidden" name="categoryId" value="@ViewBag.CurrentCategory" />
                <div class="input-group">
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="اسم الكتاب أو المؤلف..." />
                    <button class="btn btn-library" type="submit"><i class="bi bi-search"></i></button>
                </div>
            </form>

            <h6 style="color: var(--wood-medium);">الأقسام</h6>
            <ul class="list-unstyled">
                <li><a asp-action="Index" class="text-decoration-none @(ViewBag.CurrentCategory == null ? "fw-bold" : "")">كل الأقسام</a></li>
                @foreach (var cat in categories)
                {
                    <li>
                        <a asp-action="Index" asp-route-categoryId="@cat.Id" 
                           class="text-decoration-none @(ViewBag.CurrentCategory == cat.Id ? "fw-bold" : "")"
                           style="color: var(--wood-medium);">
                            @cat.Name
                        </a>
                    </li>
                }
            </ul>

            <h6 class="mt-3" style="color: var(--wood-medium);">السعر</h6>
            <form asp-action="Index" method="get">
                <input type="hidden" name="categoryId" value="@ViewBag.CurrentCategory" />
                <input type="hidden" name="search" value="@ViewBag.Search" />
                <div class="d-flex gap-2 mb-2">
                    <input type="number" name="minPrice" value="@ViewBag.MinPrice" class="form-control form-control-sm" placeholder="من" />
                    <input type="number" name="maxPrice" value="@ViewBag.MaxPrice" class="form-control form-control-sm" placeholder="إلى" />
                </div>
                <button class="btn btn-library btn-sm w-100" type="submit">فلترة</button>
            </form>
        </div>
    </div>

    @* الكتب *@
    <div class="col-md-9">
        <div class="row g-4">
            @foreach (var book in Model)
            {
                <div class="col-6 col-lg-4">
                    <div class="book-card h-100">
                        <a asp-action="Details" asp-route-id="@book.Id">
                            <img src="@(string.IsNullOrEmpty(book.CoverImageUrl) ? "/images/default-book.jpg" : book.CoverImageUrl)" alt="@book.Title" />
                        </a>
                        <div class="card-body">
                            <h6><a asp-action="Details" asp-route-id="@book.Id" class="text-decoration-none" style="color: var(--text-dark);">@book.Title</a></h6>
                            <p class="text-muted small mb-2">@book.Author</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="price">@book.Price.ToString("0.##") ج.م</span>
                                <a asp-controller="Cart" asp-action="Add" asp-route-bookId="@book.Id" class="btn btn-library btn-sm">
                                    <i class="bi bi-bag-plus"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (!Model.Any())
        {
            <p class="text-center text-muted py-5">لا توجد نتائج مطابقة.</p>
        }

        @* Pagination *@
        @if (ViewBag.TotalPages > 1)
        {
            <nav class="mt-4">
                <ul class="pagination justify-content-center">
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                            <a class="page-link" asp-action="Index" 
                               asp-route-page="@i" asp-route-categoryId="@ViewBag.CurrentCategory" 
                               asp-route-search="@ViewBag.Search">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</div>
@* Views/Account/Login.cshtml *@
@model LoginViewModel
@{
    ViewData["Title"] = "تسجيل الدخول";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card p-4" style="border-color: var(--gold); border-width: 2px;">
            <h3 class="text-center mb-4" style="color: var(--wood-medium); font-family:'Cinzel',serif;">تسجيل الدخول</h3>

            <form asp-action="Login" asp-route-returnUrl="@ViewBag.ReturnUrl" method="post">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label class="form-label fw-bold">البريد الإلكتروني</label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">كلمة المرور</label>
                    <input asp-for="Password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <div class="form-check mb-3">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label class="form-check-label">تذكرني</label>
                </div>

                <button type="submit" class="btn btn-library btn-lg w-100">دخول</button>
            </form>

            <p class="text-center mt-3">
                مفيش حساب؟ <a asp-action="Register">أنشئي حساب جديد</a>
            </p>
        </div>
    </div>
</div>
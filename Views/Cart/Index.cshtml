@* Views/Cart/Index.cshtml *@
@model Cart
@{
    ViewData["Title"] = "سلة المشتريات";
    var total = Model.CartItems.Sum(ci => ci.Book.Price * ci.Quantity);
}

<h2 class="mb-4" style="color: var(--wood-medium); font-family: 'Cinzel', serif;">سلة المشتريات</h2>

@if (!Model.CartItems.Any())
{
    <div class="text-center py-5">
        <p class="text-muted fs-5">سلتك فارغة حاليًا.</p>
        <a asp-controller="Books" asp-action="Index" class="btn btn-library">تصفحي الكتب</a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table align-middle">
            <thead style="background: var(--wood-medium); color: var(--cream);">
                <tr>
                    <th>الكتاب</th>
                    <th>السعر</th>
                    <th>الكمية</th>
                    <th>الإجمالي</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.CartItems)
                {
                    <tr>
                        <td class="d-flex align-items-center gap-2">
                            <img src="@(string.IsNullOrEmpty(item.Book.CoverImageUrl) ? "/images/default-book.jpg" : item.Book.CoverImageUrl)" 
                                 style="width:50px;height:70px;object-fit:cover;" />
                            @item.Book.Title
                        </td>
                        <td>@item.Book.Price.ToString("0.##") ج.م</td>
                        <td>
                            <form asp-action="UpdateQuantity" method="post" class="d-flex gap-1">
                                <input type="hidden" name="cartItemId" value="@item.Id" />
                                <input type="number" name="quantity" value="@item.Quantity" min="0" 
                                       class="form-control form-control-sm" style="width:70px;" 
                                       onchange="this.form.submit()" />
                            </form>
                        </td>
                        <td>@((item.Book.Price * item.Quantity).ToString("0.##")) ج.م</td>
                        <td>
                            <form asp-action="Remove" method="post">
                                <input type="hidden" name="cartItemId" value="@item.Id" />
                                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-4 p-3" style="background: var(--parchment); border-radius: 8px;">
        <h4 style="color: var(--wood-medium);">الإجمالي: @total.ToString("0.##") ج.م</h4>
        <a asp-controller="Orders" asp-action="Checkout" class="btn btn-library btn-lg">إتمام الطلب</a>
    </div>
}
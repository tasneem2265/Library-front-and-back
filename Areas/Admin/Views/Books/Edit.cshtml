@model BookFormViewModel
@{
    ViewData["Title"] = "تعديل كتاب";
    Layout = "_AdminLayout";
    var categories = ViewBag.Categories as List<Category>;
}

<h3 class="mb-4" style="color: var(--wood-medium); font-family:'Cinzel',serif;">تعديل الكتاب</h3>

<form asp-action="Edit" method="post" enctype="multipart/form-data" class="card p-4">
    <input asp-for="Id" type="hidden" />

    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label fw-bold">العنوان</label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label class="form-label fw-bold">المؤلف</label>
            <input asp-for="Author" class="form-control" />
            <span asp-validation-for="Author" class="text-danger"></span>
        </div>
        <div class="col-12">
            <label class="form-label fw-bold">الوصف</label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        </div>
        <div class="col-md-4">
            <label class="form-label fw-bold">السعر</label>
            <input asp-for="Price" class="form-control" />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label class="form-label fw-bold">الكمية بالمخزون</label>
            <input asp-for="StockQuantity" class="form-control" />
        </div>
        <div class="col-md-4 d-flex align-items-end">
            <div class="form-check">
                <input asp-for="IsAvailable" class="form-check-input" />
                <label class="form-check-label fw-bold">متاح للبيع</label>
            </div>
        </div>

        <div class="col-md-6">
            <label class="form-label fw-bold">صورة الغلاف</label>
            <input asp-for="CoverImage" type="file" class="form-control" accept="image/*" />
            @if (!string.IsNullOrEmpty(Model.ExistingImageUrl))
            {
                <img src="@Model.ExistingImageUrl" class="mt-2" style="width:80px;height:110px;object-fit:cover;" />
            }
        </div>

        <div class="col-md-6">
            <label class="form-label fw-bold">الأقسام</label>
            <div class="d-flex flex-wrap gap-3 border rounded p-2">
                @foreach (var cat in categories)
                {
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="SelectedCategoryIds" value="@cat.Id"
                               checked="@(Model.SelectedCategoryIds != null && Model.SelectedCategoryIds.Contains(cat.Id))" />
                        <label class="form-check-label">@cat.Name</label>
                    </div>
                }
            </div>
        </div>
    </div>

    <button type="submit" class="btn btn-library btn-lg mt-4">حفظ</button>
</form>
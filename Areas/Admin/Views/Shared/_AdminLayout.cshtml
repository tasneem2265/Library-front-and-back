@* Areas/Admin/Views/Shared/_AdminLayout.cshtml *@
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>لوحة التحكم - @ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@600&family=Tajawal&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/admin.css" />
</head>
<body>
    <div class="admin-wrapper">
        <aside class="admin-sidebar">
            <h4 class="text-center py-3" style="color: var(--gold-light); font-family: 'Cinzel', serif;">لوحة التحكم</h4>
            <ul class="nav flex-column">
                <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2"></i> الرئيسية</a></li>
                <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Books" asp-action="Index"><i class="bi bi-book"></i> الكتب</a></li>
                <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Categories" asp-action="Index"><i class="bi bi-tags"></i> الأقسام</a></li>
                <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Orders" asp-action="Index"><i class="bi bi-receipt"></i> الطلبات</a></li>
                <li class="nav-item mt-4"><a class="nav-link" asp-controller="Home" asp-action="Index"><i class="bi bi-box-arrow-left"></i> رجوع للموقع</a></li>
            </ul>
        </aside>
        <main class="admin-content">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">@TempData["Error"]</div>
            }
            @RenderBody()
        </main>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
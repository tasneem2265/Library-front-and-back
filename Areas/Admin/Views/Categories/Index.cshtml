@* Areas/Admin/Views/Categories/Index.cshtml *@
@model List<Category>
@{
    ViewData["Title"] = "إدارة الأقسام";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 style="color: var(--wood-medium); font-family:'Cinzel',serif;">إدارة الأقسام</h3>
    <a asp-action="Create" class="btn btn-library"><i class="bi bi-plus-lg"></i> إضافة قسم</a>
</div>

<table class="table bg-white">
    <thead style="background: var(--wood-medium); color: var(--cream);">
        <tr>
            <th>الاسم</th>
            <th>الوصف</th>
            <th>عدد الكتب</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var cat in Model)
        {
            <tr>
                <td>@cat.Name</td>
                <td>@cat.Description</td>
                <td>@cat.BookCategories.Count</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@cat.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                    <form asp-action="Delete" asp-route-id="@cat.Id" method="post" class="d-inline" onsubmit="return confirm('متأكدة من الحذف؟');">
                        <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
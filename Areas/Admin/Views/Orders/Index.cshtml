@* Areas/Admin/Views/Orders/Index.cshtml *@
@model List<Order>
@{
    ViewData["Title"] = "إدارة الطلبات";
    Layout = "_AdminLayout";

    string StatusLabel(OrderStatus s) => s switch
    {
        OrderStatus.Pending => "قيد التجهيز",
        OrderStatus.Shipped => "تم الشحن",
        OrderStatus.Delivered => "تم التسليم",
        OrderStatus.Cancelled => "ملغي",
        _ => ""
    };

    string StatusColor(OrderStatus s) => s switch
    {
        OrderStatus.Pending => "warning",
        OrderStatus.Shipped => "info",
        OrderStatus.Delivered => "success",
        OrderStatus.Cancelled => "danger",
        _ => "secondary"
    };
}

<h3 class="mb-4" style="color: var(--wood-medium); font-family:'Cinzel',serif;">إدارة الطلبات</h3>

<div class="mb-3">
    <a asp-action="Index" class="btn btn-sm @(ViewBag.CurrentStatus == null ? "btn-library" : "btn-outline-secondary")">الكل</a>
    @foreach (OrderStatus s in Enum.GetValues(typeof(OrderStatus)))
    {
        <a asp-action="Index" asp-route-status="@s" class="btn btn-sm @(ViewBag.CurrentStatus?.Equals(s) == true ? "btn-library" : "btn-outline-secondary")">@StatusLabel(s)</a>
    }
</div>

<table class="table bg-white">
    <thead style="background: var(--wood-medium); color: var(--cream);">
        <tr>
            <th>رقم الطلب</th>
            <th>العميل</th>
            <th>التاريخ</th>
            <th>عدد العناصر</th>
            <th>الإجمالي</th>
            <th>الحالة</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>#@order.Id</td>
                <td>@order.ApplicationUser?.FullName</td>
                <td>@order.OrderDate.ToString("dd/MM/yyyy")</td>
                <td>@order.OrderItems.Count</td>
                <td>@order.TotalAmount.ToString("0.##") ج.م</td>
                <td><span class="badge bg-@StatusColor(order.Status)">@StatusLabel(order.Status)</span></td>
                <td><a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary">التفاصيل</a></td>
            </tr>
        }
    </tbody>
</table>